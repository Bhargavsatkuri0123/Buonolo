rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Phase 3: Primitives
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // -------------------------------------------------------------------------
    // Phase 2/4: Validation Blueprints
    // -------------------------------------------------------------------------
    function isValidProfile(data) {
      return data.id == request.auth.uid
        && data.full_name is string && data.full_name.size() >= 0
        && data.updated_at is string
        && (data.get('saved_items', []) is list)
        && (data.get('saved_locations', []) is list)
        && (data.get('notifications_enabled', true) is bool)
        && (data.get('preferred_radius', 10) is number);
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'description', 'admin_id', 'admin_name', 'created_at'])
        && data.name is string && data.name.size() > 0
        && data.description is string && data.description.size() >= 0
        && data.admin_id == request.auth.uid
        && data.admin_name is string && data.admin_name.size() > 0
        && data.created_at is string;
    }

    function isValidGroupMember(data) {
      return data.keys().hasAll(['user_id', 'user_name'])
        && data.user_id == request.auth.uid
        && data.user_name is string && data.user_name.size() > 0;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['content', 'author_id', 'author_name', 'created_at'])
        && data.author_id == request.auth.uid
        && data.author_name is string && data.author_name.size() > 0
        && data.content is string && data.content.size() > 0
        && data.created_at is string
        && (data.get('likes', []) is list)
        && (data.get('comments_count', 0) is number);
    }

    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Collections
    // -------------------------------------------------------------------------
    match /profiles/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidProfile(incoming());
      // Using hasOnly and diff to validate updates securely if we were strict, but simple validation is minimal
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidProfile(incoming());
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update, delete: if isSignedIn() && existing().author_id == request.auth.uid;
    }

    match /groups/{groupId} {
      // Anyone signed in can read groups
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming());
      // Only admin can update, cannot change admin
      allow update: if isSignedIn() && isValidId(groupId) 
        && existing().admin_id == request.auth.uid 
        && isValidGroup(incoming())
        && incoming().admin_id == existing().admin_id; 
    }

    match /groups/{groupId}/members/{memberId} {
      allow read: if isSignedIn();
      // Users can join a group (create doc with their own ID)
      allow create: if isSignedIn() && isValidId(groupId) && isValidId(memberId) && memberId == request.auth.uid && isValidGroupMember(incoming());
      // Users can leave a group
      allow delete: if isSignedIn() && memberId == request.auth.uid;
    }

    match /groups/{groupId}/updates/{updateId} {
      allow read: if isSignedIn();
      // Only admin can create updates
      allow create: if isSignedIn() && isValidId(groupId) && isValidId(updateId) 
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && get(/databases/$(database)/documents/groups/$(groupId)).data.admin_id == request.auth.uid
        && incoming().keys().hasAll(['author_id', 'author_name', 'content', 'created_at'])
        && incoming().author_id == request.auth.uid
        && incoming().content is string && incoming().content.size() > 0
        && incoming().created_at is string;
    }
  }
}
