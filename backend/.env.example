PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://buonolo:buonolo@localhost:5432/buonolo

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_SECONDS=2592000

# CORS (web dev server origin; not needed in prod when Nginx fronts both on one origin)
CORS_ORIGIN=http://localhost:3000

# Uploads
UPLOAD_DIR=./uploads

# Gemini (server-side only, never exposed to clients)
GEMINI_API_KEY=

# Storage backend — "s3" to upload to AWS S3, "local" (default) for disk
STORAGE_BACKEND=local
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
S3_PUBLIC_BASE_URL=
