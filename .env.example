# Copy this file to .env and fill in real values before running `docker compose up`.

# --- Postgres ---
POSTGRES_USER=buonolo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=buonolo

# --- Auth (generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- "Sign in with Google" (in-app login option, distinct from the Microsoft SSO
# gate below). OAuth Client ID from Google Cloud Console; leave unset to disable. ---
GOOGLE_CLIENT_ID=
# Same Client ID, exposed to the web build (Vite only inlines VITE_-prefixed vars).
VITE_GOOGLE_CLIENT_ID=

# --- CORS (only matters if you serve the frontend from a different origin than Nginx) ---
CORS_ORIGIN=https://qa.buonolo.com

# --- Gemini (server-side only, powers the "Mr O" assistant) ---
GEMINI_API_KEY=

# --- Nginx ---
HTTP_PORT=80

# Storage backend — set to "s3" to use AWS S3, "local" (default) for disk
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=buonolo
# Set once the CloudFront origin/behavior for S3 uploads is live, e.g.:
# S3_PUBLIC_BASE_URL=https://qa.pearwave.com/s3-uploads
S3_PUBLIC_BASE_URL=https://qa.buonolo.com/s3-uploads

# --- Microsoft Entra ID (Azure AD) SSO gate for the QA site (oauth2-proxy) ---
# See README for the exact Azure Portal steps to create these.
AZURE_TENANT_ID=
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# generate with: openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=
# Public URL of the QA site (used to build the OIDC redirect URI). Register
# this exact callback in the Azure app registration: https://qa.buonolo.com/oauth2/callback
QA_SITE_URL=https://qa.buonolo.com
# CloudFront/ALB terminates TLS in front of the instance, so the browser-facing
# site is HTTPS even though nginx itself only listens on plain HTTP — cookies
# must be marked secure. Only set this to "false" if testing directly over
# http:// with no TLS-terminating proxy in front yet.
OAUTH2_PROXY_COOKIE_SECURE=true
